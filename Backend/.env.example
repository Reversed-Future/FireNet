APP_NAME=Firelens Data Backend
APP_ENV=development
DATABASE_URL=postgresql://firelens:firelens@localhost:5432/fire
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:3000","http://127.0.0.1:5173"]
SEED_CSV_PATH=data/seed_fire_points.csv

# NASA FIRMS WFS Configuration (REQUIRED for Update Data feature)
# Create a key at https://firms.modaps.eosdis.nasa.gov/
FIRMS_MAP_KEY=your-firms-api-key-here
FIRMS_WFS_REGION=SouthEast_Asia
FIRMS_WFS_TYPENAME=ms:fires_snpp_24hrs
FIRMS_WFS_BBOX=-90,-180,90,180
FIRMS_WFS_COUNT=1000
PORT=8000
SCHEDULER_ENABLED=false
SCHEDULER_INTERVAL_MINUTES=60
